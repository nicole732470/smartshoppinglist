<%= form_with model: product, local: true do |f| %>
  <% if product.errors.any? %>
    <div class="alert alert-danger">
      <ul class="mb-0">
        <% product.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3">
    <%= f.label :name, "Product Name", class: "form-label fw-semibold" %>
    <%= f.text_field :name, class: "form-control", placeholder: "e.g. Apple iPhone 15 Pro" %>
  </div>

  <div class="mb-3">
    <%= f.label :category, "Category", class: "form-label fw-semibold" %>
    <%= f.select :category,
        ["Electronics", "Computers & Laptops", "TVs & Home Theater", "Cameras", "Gaming", "Appliances", "Clothing & Shoes", "Books", "Sports & Outdoors", "Beauty", "Other"],
        { prompt: "Select a category" },
        class: "form-select" %>
  </div>

  <div class="mb-3">
    <%= f.label :description, "Description", class: "form-label fw-semibold" %>
    <%= f.text_area :description, class: "form-control", rows: 3, placeholder: "Brief description of the product..." %>
  </div>

  <div class="mb-3">
    <%= f.label :image_url, "Image URL (optional)", class: "form-label fw-semibold" %>
    <%= f.text_field :image_url, class: "form-control", placeholder: "https://..." %>
    <div class="form-text">Will be filled automatically by scraper in a future version.</div>
  </div>

  <%= f.submit product.new_record? ? "Add Product" : "Save Changes", class: "btn btn-primary w-100" %>
<% end %>