<!DOCTYPE html>
<html>
  <head>
    <title>PriceTracker</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
      <div class="container">
        <%= link_to "💰 PriceTracker", root_path, class: "navbar-brand" %>
        <div class="navbar-nav me-auto">
          <%= link_to "Products", products_path, class: "nav-link #{controller_name == 'products' ? 'active' : ''}" %>
          <%= link_to "Price Records", price_records_path, class: "nav-link #{controller_name == 'price_records' ? 'active' : ''}" %>
        </div>
        <div class="d-flex gap-2">
          <%= link_to "+ Add Product", new_product_path, class: "btn btn-outline-light btn-sm" %>
        </div>
      </div>
    </nav>

    <% if notice %>
      <div class="alert alert-success m-3" role="alert">
        <%= notice %>
      </div>
    <% end %>

    <% if alert %>
      <div class="alert alert-danger m-3" role="alert">
        <%= alert %>
      </div>
    <% end %>

    <%= yield %>

    <footer class="bg-dark text-white text-center py-3 mt-5">
      <small>PriceTracker © 2025 — Track every price change</small>
    </footer>
  </body>
</html>