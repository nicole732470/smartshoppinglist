<div class="container mt-4" style="max-width: 600px;">
  <h2>➕ Add Price Record</h2>
  <p class="text-muted">Adding price for <strong><%= @product.name %></strong></p>
  <div class="card shadow-sm">
    <div class="card-body">
      <%= render 'form', price_record: @price_record, product: @product %>
    </div>
  </div>
  <div class="mt-2">
    <%= link_to "← Back to Product", @product, class: "btn btn-outline-secondary" %>
  </div>
</div>