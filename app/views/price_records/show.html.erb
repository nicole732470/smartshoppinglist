<div class="container mt-4" style="max-width: 600px;">
  <nav aria-label="breadcrumb">
    <ol class="breadcrumb">
      <li class="breadcrumb-item"><%= link_to "Home", root_path %></li>
      <li class="breadcrumb-item"><%= link_to "Price Records", price_records_path %></li>
      <li class="breadcrumb-item active">Record #<%= @price_record.id %></li>
    </ol>
  </nav>

  <div class="card shadow-sm">
    <div class="card-header bg-dark text-white">
      <h5 class="mb-0">Price Record #<%= @price_record.id %></h5>
    </div>
    <div class="card-body">
      <dl class="row">
        <dt class="col-sm-4">Product</dt>
        <dd class="col-sm-8"><%= link_to @price_record.product.name, @price_record.product %></dd>

        <dt class="col-sm-4">Price</dt>
        <dd class="col-sm-8"><span class="badge bg-success fs-5">$<%= sprintf("%.2f", @price_record.price) %></span></dd>

        <dt class="col-sm-4">Store</dt>
        <dd class="col-sm-8"><strong><%= @price_record.store_name %></strong></dd>

        <dt class="col-sm-4">Date Recorded</dt>
        <dd class="col-sm-8"><%= @price_record.recorded_at.strftime("%B %d, %Y at %I:%M %p") %></dd>

        <dt class="col-sm-4">Purchase Link</dt>
        <dd class="col-sm-8">
          <% if @price_record.url.present? %>
            <%= link_to "🛒 Buy Now", @price_record.url, target: "_blank", class: "btn btn-success btn-sm" %>
            <br><small class="text-muted"><%= @price_record.url %></small>
          <% else %>
            <span class="text-muted">No link provided</span>
          <% end %>
        </dd>

        <dt class="col-sm-4">Notes</dt>
        <dd class="col-sm-8"><%= @price_record.notes.present? ? @price_record.notes : "—" %></dd>
      </dl>
    </div>
    <div class="card-footer d-flex gap-2">
      <%= link_to "✏️ Edit", edit_price_record_path(@price_record), class: "btn btn-outline-secondary" %>
      <%= link_to "🗑️ Delete", @price_record, data: { turbo_method: :delete, turbo_confirm: "Delete this record?" }, class: "btn btn-outline-danger" %>
      <%= link_to "← Back to Product", @price_record.product, class: "btn btn-outline-primary" %>
      <%= link_to "All Records", price_records_path, class: "btn btn-outline-dark" %>
    </div>
  </div>
</div>